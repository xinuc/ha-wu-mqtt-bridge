#!/command/with-contenv bashio
# shellcheck shell=bash
# ==============================================================================
# Take down the S6 supervision tree when the service crashes
# ==============================================================================

declare exit_code_service="${1}"
declare exit_code_signal="${2}"

if test "${exit_code_service}" -eq 256; then
    exit_code_service=$((128 + exit_code_signal))
fi

if test "${exit_code_service}" -ne 0; then
    bashio::log.warning \
        "wu-mqtt-bridge exited with code ${exit_code_service} (signal ${exit_code_signal})"
    echo "${exit_code_service}" > /run/s6-linux-init-container-results/exitcode
    exec /run/s6/basedir/bin/halt
fi

bashio::log.info "wu-mqtt-bridge stopped cleanly."
